[global]
    font = "Product Sans 11"
    allow_markup = yes
    format = "<b>%s</b>\n%b"
    sort = yes
    indicate_hidden = yes
    alignment = left
    bounce_freq = 0
    ellipsize = middle
    show_age_threshold = -1
    word_wrap = yes
    ignore_newline = no

    width = 350
    height = 200
    origin = top-right
    offset = 20x50
    scale = 0
    notification_limit = 5

    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 350
    progress_bar_corner_radius = 5

    fixed_get_geometry = true
    frame_width = 2
    frame_color = "#333333"
    separator_color = frame

    # Transparency (0-100, 0 is opaque)
    transparency = 10
    separator_height = 2
    padding = 15
    horizontal_padding = 15
    text_icon_padding = 15

    idle_threshold = 120
    monitor = 0
    follow = mouse
    sticky_history = yes
    line_height = 3

    show_indicators = no
    icon_position = left
    min_icon_size = 32
    max_icon_size = 64
    icon_path = /usr/share/icons/gnome/16x16/status/:/usr/share/icons/gnome/16x16/devices/

    corner_radius = 12
    always_run_script = true

    # ACTIONS: Click to open (context) or follow link
    mouse_left_click = do_action, close_current
    mouse_middle_click = close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#313244"
    timeout = 5

[urgency_normal]
    background = "#2a2a2a"
    foreground = "#eeeeee"
    frame_color = "#444444"
    highlight = "#ffffff"
    timeout = 10

[urgency_critical]
    background = "#333333"
    foreground = "#ffffff"
    frame_color = "#fb4934"
    highlight = "#fb4934"
    timeout = 0
[backlight]
	summary = "Backlight"
	highlight = "#dcdcdc"
	set_stack_tag = "backlight"

[volume]
	summary = "Volume"
	set_stack_tag = "volume"

[volume-muted]
	summary = "Volume Muted"
	highlight = "#a0a0a0"

[volume-unmuted]
	summary = "Volume Unmuted"
	highlight = "#dcdcdc"
